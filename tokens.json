{
  "manifest": {
    "name": "ROBR - UI Mockups",
    "version": "0.1.0",
    "description": "Interactive UI mockups for ROBR MMORPG - Multi-platform (PC, Console, Mobile)",
    "style": "Low-poly 3D with Brazilian folklore aesthetic"
  },
  "platforms": {
    "pc": {"resolution": "1920x1080", "aspect": "16:9"},
    "console": {"resolution": "1920x1080", "aspect": "16:9", "safe_area": "90%"},
    "mobile": {"resolution": "1080x1920", "aspect": "9:16", "touch_min": "44px"}
  },
  "color_palette": {
    "primary": "#2D6A4F",
    "secondary": "#40916C",
    "accent": "#D4A373",
    "health": "#22C55E",
    "mana": "#3B82F6",
    "xp": "#A855F7",
    "rare": "#3B82F6",
    "epic": "#A855F7",
    "legendary": "#F97316",
    "bg_dark": "#0D1117",
    "bg_panel": "#161B22",
    "bg_card": "#21262D",
    "border": "#30363D",
    "text_primary": "#E6EDF3",
    "text_secondary": "#8B949E",
    "gold": "#FFD700"
  },
  "typography": {
    "font_primary": "'Segoe UI', 'Roboto', sans-serif",
    "font_display": "'Cinzel', 'Georgia', serif"
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "border_radius": {
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "pill": "9999px"
  }
}
